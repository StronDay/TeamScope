{
  "$schema": "https://json.schemastore.org/ocelot.json",
  "Routes": [
    {
      "DownstreamPathTemplate": "/api/Staff{everything}",
      "DownstreamScheme": "http",
      "DownstreamHostAndPorts": [
        {
          "Host": "staff_service",
          "Port": 5022
        }
      ],
      "UpstreamPathTemplate": "/api/Staff/{everything}",
      "UpstreamHttpMethod": [ "GET", "POST", "PUT", "DELETE" ],
      "SwaggerKey": "staff"
    },
    {
      "DownstreamPathTemplate": "/api/Auth/{everything}",
      "DownstreamScheme": "http",
      "DownstreamHostAndPorts": [
        {
          "Host": "auth_service",
          "Port": 5066
        }
      ],
      "UpstreamPathTemplate": "/api/Auth/{everything}",
      "UpstreamHttpMethod": [ "GET", "POST", "PUT", "DELETE" ],
      "SwaggerKey": "auth"
    }
  ],
  "SwaggerEndPoints": [
    {
      "Key": "staff",
      "Config": [
        {
          "Name": "Staff Service",
          "Version": "v1",
          "Url": "http://staff_service:5022/swagger/v1/swagger.json"
        }
      ]
    },
    {
      "Key": "auth",
      "Config": [
        {
          "Name": "Auth Service",
          "Version": "v1",
          "Url": "http://auth_service:5066/swagger/v1/swagger.json"
        }
      ]
    }
  ]
}